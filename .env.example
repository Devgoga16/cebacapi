# Variables de entorno para desarrollo local
# Copia este archivo como .env y configura tus valores

# MongoDB Atlas URI (reemplaza con tu cadena de conexión real)
MONGODB_URI=mongodb+srv://monkeywit:kwT1YISBooBOqKEG@cluster0.2elgi.mongodb.net/cebac?retryWrites=true&w=majority&appName=Cluster0

# Puerto del servidor (opcional, por defecto 3000)
